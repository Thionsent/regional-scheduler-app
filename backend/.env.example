NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/regional_scheduler?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/regional_scheduler?schema=public
ACCESS_TOKEN_SECRET=replace-with-a-long-random-access-token-secret
REFRESH_TOKEN_PEPPER=replace-with-a-long-random-refresh-token-pepper
OTP_PEPPER=replace-with-a-long-random-otp-pepper
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
OTP_TTL_MINUTES=10
SMS_PROVIDER=console
# Set these when SMS_PROVIDER=africas_talking. Never expose them to the client.
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-webhook-token
